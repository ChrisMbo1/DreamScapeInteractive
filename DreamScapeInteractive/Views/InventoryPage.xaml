<?xml version="1.0" encoding="utf-8"?>
<Page
x:Class="DreamScapeInteractive.Views.InventoryPage"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:local="using:DreamScapeInteractive.Views"
xmlns:Model="using:DreamScapeInteractive.Model"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
mc:Ignorable="d">
    <Grid Background="#1E1E1E">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel Orientation="Vertical" Spacing="15">
                <Button Content="Back" Click="BackButton_Click" HorizontalAlignment="Left" Padding="10,5" Background="#0078D4" Foreground="White" FontSize="14"/>
                
                <StackPanel Spacing="20">
                    <!-- Header Section -->
                    <StackPanel Orientation="Vertical" Spacing="5">
                        <TextBlock Text="Your Inventory" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#FFFFFF"/>
                        <TextBlock Text="Manage and view your collected items" FontSize="12" Foreground="#B0B0B0" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Items Card -->
                    <Border Background="#2D2D2D" CornerRadius="8" Padding="20" BorderThickness="1" BorderBrush="#404040">
                        <StackPanel Orientation="Vertical" Spacing="15">
                            <!-- Column Headers -->
                            <StackPanel Orientation="Horizontal" Padding="10,0" Spacing="20">
                                <TextBlock Text="Item Name" FontSize="14" FontWeight="SemiBold" Foreground="#B0B0B0" Width="250"/>
                                <TextBlock Text="Quantity" FontSize="14" FontWeight="SemiBold" Foreground="#B0B0B0"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="10" Padding="0,0,0,10">
                                <ComboBox x:Name="TypeFilterCombo" Width="120" SelectionChanged="Filter_Changed">
                                    <ComboBoxItem Content="All Types" IsSelected="True"/>
                                    <ComboBoxItem Content="Weapon"/>
                                    <ComboBoxItem Content="Armor"/>
                                    <ComboBoxItem Content="Consumable"/>
                                    <ComboBoxItem Content="Accessory"/>
                                    <ComboBoxItem Content="Potion"/>
                                </ComboBox>

                                <ComboBox x:Name="RarityFilterCombo" Width="120" SelectionChanged="Filter_Changed">
                                    <ComboBoxItem Content="All Rarity" IsSelected="True"/>
                                    <ComboBoxItem Content="Common"/>
                                    <ComboBoxItem Content="Uncommon"/>
                                    <ComboBoxItem Content="Rare"/>
                                    <ComboBoxItem Content="Epic"/>
                                    <ComboBoxItem Content="Legendary"/>
                                </ComboBox>
                            </StackPanel>

                            <Rectangle Height="1" Fill="#404040"/>

                            <ListView x:Name="InventoryList" 
                                      SelectionMode="None"
                                      Background="#1E1E1E">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="Model:Inventory">
                                        <StackPanel Orientation="Horizontal" Padding="10,8" Spacing="20">
                                            <TextBlock Text="{x:Bind Item.Name}" FontSize="16" Width="250" Foreground="#E0E0E0" FontWeight="Medium"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="x" FontSize="16" Foreground="#B0B0B0"/>
                                                <TextBlock Text="{x:Bind Quantity}" FontSize="16" Foreground="#E0E0E0" FontWeight="SemiBold" MinWidth="30"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <StackPanel Orientation="Vertical" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="20">
                                <TextBlock x:Name="NoItemsText" Text="You have no items in your inventory." 
                                           FontSize="16" FontStyle="Italic" 
                                           HorizontalAlignment="Center" 
                                           Foreground="#B0B0B0"
                                           Visibility="Collapsed"/>
                                <TextBlock Text="Complete quests or trade with other players to earn items!" 
                                           FontSize="12" FontStyle="Italic" 
                                           HorizontalAlignment="Center" 
                                           Foreground="#808080"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Tip: Items are automatically stored when you complete quests or receive them from trades." 
                               FontSize="12" Foreground="#808080" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
