<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DreamScapeInteractive.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DreamScapeInteractive.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">


    <Grid Padding="20" VerticalAlignment="Center">

        <StackPanel Width="300" Spacing="12">

            <TextBlock Text="Login" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>

            <TextBox x:Name="UsernameInput" PlaceholderText="Username" />
            <PasswordBox x:Name="PasswordInput" PlaceholderText="Password"/>

            <Button Content="Login" Click="LoginButton_Click"/>

            <TextBlock Text="Don't have an account?" HorizontalAlignment="Center"/>
            <Button Content="Register" Click="GoToRegister_Click"/>

            <TextBlock x:Name="ErrorText" Foreground="Red" Visibility="Collapsed"/>
        </StackPanel>

    </Grid>
</Page>
