<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DreamScapeInteractive.Views.AdminPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DreamScapeInteractive.Views"
    xmlns:Model="using:DreamScapeInteractive.Model"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#1E1E1E">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Orientation="Vertical" Spacing="15" Padding="20">
                <Button Content="Back" Click="BackButton_Click" HorizontalAlignment="Left" Padding="10,5" Background="#0078D4" Foreground="White" FontSize="14"/>
                
                <StackPanel Orientation="Vertical" Spacing="15">
                    <TextBlock Text="Admin Panel" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#FFFFFF"/>
                    
                    <!-- Admin Actions -->
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                        <Button Content="Create Item" Click="CreateItem_Click" Padding="12,8" Background="#4CAF50" Foreground="White" FontSize="14"/>
                        <Button Content="Edit Items" Click="EditItem_Click" Padding="12,8" Background="#2196F3" Foreground="White" FontSize="14"/>
                    </StackPanel>

                    <!-- Users List -->
                    <Border Background="#2D2D2D" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#404040">
                        <StackPanel Orientation="Vertical" Spacing="10">
                            <TextBlock Text="Users" FontSize="16" FontWeight="SemiBold" Foreground="#E0E0E0"/>
                            <ListView x:Name="UsersList" SelectionMode="Single" Height="200" Background="#1E1E1E">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="Model:User">
                                        <StackPanel Orientation="Horizontal" Spacing="20" Padding="8">
                                            <TextBlock Text="{x:Bind Username}" Width="150" FontSize="16" Foreground="#E0E0E0"/>
                                            <TextBlock Text="{x:Bind Role.Roles}" Width="100" FontSize="14" Foreground="#B0B0B0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- Items List -->
                    <Border Background="#2D2D2D" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#404040">
                        <StackPanel Orientation="Vertical" Spacing="10">
                            <TextBlock Text="Select Items to Give" FontSize="16" FontWeight="SemiBold" Foreground="#E0E0E0"/>
                            <ListView x:Name="ItemsListView" SelectionMode="Multiple" Height="250" Background="#1E1E1E">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="Model:Item">
                                        <TextBlock Text="{x:Bind Name}" FontSize="16" Padding="8" Foreground="#E0E0E0"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- Quantity and Button -->
                    <Border Background="#2D2D2D" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#404040">
                        <StackPanel Orientation="Vertical" Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <TextBlock Text="Quantity:" FontSize="14" VerticalAlignment="Center" Foreground="#B0B0B0" FontWeight="SemiBold"/>
                                <TextBox x:Name="QuantityInput" Width="80" PlaceholderText="Qty" Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#404040"/>
                            </StackPanel>
                            <Button Content="Give Selected Items" Click="GiveSelectedItems_Click" Padding="12,8" Background="#FF9800" Foreground="White" HorizontalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
