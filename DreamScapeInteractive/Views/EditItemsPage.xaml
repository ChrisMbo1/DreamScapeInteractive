<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DreamScapeInteractive.Views.EditItemsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DreamScapeInteractive.Views"
        xmlns:Model="using:DreamScapeInteractive.Model"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#1E1E1E">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Orientation="Vertical" Spacing="15" Padding="20">
                <Button Content="Back" Click="BackButton_Click" HorizontalAlignment="Left" Padding="10,5" Background="#0078D4" Foreground="White" FontSize="14"/>

                <StackPanel Orientation="Vertical" Spacing="15">
                    <TextBlock Text="Edit Items" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#FFFFFF"/>
                    <TextBlock Text="Modify item properties and attributes" FontSize="12" HorizontalAlignment="Center" Foreground="#B0B0B0"/>

                    <!-- Success/Error Messages -->
                    <TextBlock x:Name="SuccessMessage" Text="" FontSize="14" Foreground="#4CAF50" HorizontalAlignment="Center" Visibility="Collapsed" FontWeight="SemiBold"/>
                    <TextBlock x:Name="ErrorMessage" Text="" FontSize="14" Foreground="#FF6B6B" HorizontalAlignment="Center" Visibility="Collapsed"/>

                    <!-- Items List Section -->
                    <Border Background="#2D2D2D" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#404040">
                        <StackPanel Orientation="Vertical" Spacing="10">
                            <TextBlock Text="Select an item to edit:" FontSize="14" FontWeight="SemiBold" Foreground="#E0E0E0"/>
                            <ListView x:Name="ItemsListView" SelectionMode="Single" SelectionChanged="ItemsListView_SelectionChanged" Height="250" Background="#1E1E1E">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="Model:Item">
                                        <TextBlock Text="{x:Bind Name}" FontSize="16" Padding="10,8" Foreground="#E0E0E0"/>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- Edit Fields Section -->
                    <Border Background="#2D2D2D" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="#404040">
                        <StackPanel Orientation="Vertical" Spacing="12">
                            <TextBlock Text="Item Properties" FontSize="16" FontWeight="SemiBold" Foreground="#E0E0E0"/>
                            
                            <StackPanel Orientation="Vertical" Spacing="8">
                                <TextBlock Text="Name:" Foreground="#B0B0B0" FontSize="12" FontWeight="SemiBold"/>
                                <TextBox x:Name="NameInput" Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#404040"/>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Spacing="8">
                                <TextBlock Text="Description:" Foreground="#B0B0B0" FontSize="12" FontWeight="SemiBold"/>
                                <TextBox x:Name="DescriptionInput" Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#404040"/>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Spacing="8">
                                <TextBlock Text="Type:" Foreground="#B0B0B0" FontSize="12" FontWeight="SemiBold"/>
                                <ComboBox x:Name="TypeComboBox" Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#404040">
                                    <ComboBoxItem Content="Weapon"/>
                                    <ComboBoxItem Content="Armor"/>
                                    <ComboBoxItem Content="Potion"/>
                                    <ComboBoxItem Content="Accessory"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Spacing="8">
                                <TextBlock Text="Rarity:" Foreground="#B0B0B0" FontSize="12" FontWeight="SemiBold"/>
                                <ComboBox x:Name="RarityComboBox" Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#404040">
                                    <ComboBoxItem Content="Common"/>
                                    <ComboBoxItem Content="Uncommon"/>
                                    <ComboBoxItem Content="Rare"/>
                                    <ComboBoxItem Content="Epic"/>
                                    <ComboBoxItem Content="Legendary"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Spacing="8">
                                <TextBlock Text="Power:" Foreground="#B0B0B0" FontSize="12" FontWeight="SemiBold"/>
                                <TextBox x:Name="PowerInput" Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#404040"/>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Spacing="8">
                                <TextBlock Text="Speed:" Foreground="#B0B0B0" FontSize="12" FontWeight="SemiBold"/>
                                <TextBox x:Name="SpeedInput" Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#404040"/>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Spacing="8">
                                <TextBlock Text="Durability:" Foreground="#B0B0B0" FontSize="12" FontWeight="SemiBold"/>
                                <TextBox x:Name="DurabilityInput" Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#404040"/>
                            </StackPanel>

                            <StackPanel Orientation="Vertical" Spacing="8">
                                <TextBlock Text="Enchantments:" Foreground="#B0B0B0" FontSize="12" FontWeight="SemiBold"/>
                                <TextBox x:Name="EnchantmentsInput" Background="#1E1E1E" Foreground="#E0E0E0" BorderBrush="#404040"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Action Buttons -->
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                        <Button Content="Save Changes" Click="SaveChanges_Click" Padding="15,10" Background="#4CAF50" Foreground="White" FontSize="14" CornerRadius="4"/>
                        <Button Content="Delete Item" Click="DeleteItem_Click" Padding="15,10" Background="#F44336" Foreground="White" FontSize="14" CornerRadius="4"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
